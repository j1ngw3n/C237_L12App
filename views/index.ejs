<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Student To-Do List</title>
</head>
<body>
    
<%- include('partials/navbar') %>

<div class="container mt-4">

    <div class="text-center mb-4">
        <h1>My Tasks</h1>
        <p>Stay organised and complete your tasks on time.</p>

        <a href="/addTask" class="btn btn-primary">Add New Task</a>
    </div>

    <% if(tasks.length === 0) { %>
        <div class="alert alert-info">
            No tasks available.
        </div>
    <% } %>

    <% tasks.forEach(task => { %>

        <div class="card mb-3">
            <div class="card-body">

                <h4>
                    <% if(task.completed) { %>
                        <s><%= task.title %></s>
                    <% } else { %>
                        <%= task.title %>
                    <% } %>
                </h4>

                <p><%= task.description %></p>

                <p>
                    <strong>Due Date:</strong>
                    <%= task.dueDate %>
                </p>

                <a href="/completeTask/<%= task.id %>" class="btn btn-success btn-sm">
                    Complete
                </a>

                <a href="/editTask/<%= task.id %>" class="btn btn-warning btn-sm">
                    Edit
                </a>

                <a href="/deleteTask/<%= task.id %>" class="btn btn-danger btn-sm">
                    Delete
                </a>

            </div>
        </div>

    <% }) %>

</div>

</body>
</html>
